{
  "ConnectionStrings": {
    "DefaultConnection": "Server=#{DB_HOST}#;Database=#{DB_NAME}#;User Id=#{DB_USER}#;Password=#{DB_PASSWORD}#;"
  },
  "ServiceUrls": {
    "DocumentService": "#{DOCUMENT_SERVICE_URL}#",
    "NotificationService": "#{NOTIFICATION_SERVICE_URL}#",
    "LegacySearchApi": "#{LEGACY_SEARCH_API_URL}#",
    "GovReportApi": "#{GOV_REPORT_API_URL}#"
  },
  "StoragePaths": {
    "ArchiveBasePath": "#{ARCHIVE_BASE_PATH}#",
    "TempExportPath": "#{TEMP_EXPORT_PATH}#"
  },
  "ApiKeys": {
    "GovApiKey": "#{GOV_API_KEY}#"
  },
  "ApplicationInsights": {
    "ConnectionString": "#{APPLICATIONINSIGHTS_CONNECTION_STRING}#"
  },
  "Redis": {
    "ConnectionString": "#{REDIS_CONNECTION_STRING}#"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  }
}
