{
  "ConnectionStrings": {
    "DefaultConnection": "Server=#{AZURE_SQL_SERVER}#;Database=#{AZURE_SQL_DATABASE}#;Authentication=Active Directory Default;"
  },
  "ServiceUrls": {
    "DocumentService": "#{DOCUMENT_SERVICE_URL}#",
    "NotificationService": "#{NOTIFICATION_SERVICE_URL}#",
    "LegacySearchApi": "#{LEGACY_SEARCH_API_URL}#",
    "GovReportApi": "#{GOV_REPORT_API_URL}#"
  },
  "StoragePaths": {
    "ArchiveContainer": "archives",
    "TempExportContainer": "exports",
    "LogContainer": "logs"
  },
  "AzureStorage": {
    "AccountName": "#{AZURE_STORAGE_ACCOUNT}#",
    "BlobEndpoint": "#{AZURE_BLOB_ENDPOINT}#"
  },
  "Redis": {
    "ConnectionString": "#{REDIS_CONNECTION_STRING}#"
  },
  "ApplicationInsights": {
    "ConnectionString": "#{APPINSIGHTS_CONNECTION_STRING}#"
  },
  "KeyVault": {
    "VaultUri": "#{KEYVAULT_URI}#"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
